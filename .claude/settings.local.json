{
  "permissions": {
    "allow": [
      "Bash(cp -r ./my-app/* .)",
      "Bash(cp -r ./my-app/.[!.]* .)",
      "Bash(rm -rf ./my-app)",
      "mcp__playwright",
      "Bash(curl -s http://localhost:3000)",
      "Bash(curl -s http://localhost:3000/portfolio)",
      "Bash(git add *)",
      "Bash(git commit -m '포트폴리오 스타터킷 구현 완료 *)",
      "Bash(git commit -m 'README 업데이트: 포트폴리오 스타터킷 완전 가이드 *)",
      "Bash(npm run *)",
      "Bash(Get-ChildItem *)",
      "Skill(update-config)",
      "Skill(component:add-component)",
      "Bash(git commit -m ' *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "agent",
            "prompt": "코드 리뷰를 수행해주세요. 방금 작성/수정된 코드 파일을 분석하여 전문적인 리뷰를 제공해주세요. 코드 품질, 타입 안정성, React/Next.js 패턴, 성능, 보안을 중점적으로 검토하세요.",
            "statusMessage": "🔍 코드 리뷰 진행 중...",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "playwright_run",
    "playwright_test"
  ]
}
